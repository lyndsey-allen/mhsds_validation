
##############################
# R PROJECT IGNORE RULES
##############################

# History files
.Rhistory
.RData
.Ruserdata
.Rapp.history

# RStudio project files
.Rproj.user/
*.Rproj.user
*.Rproj
.Rproj.user/*

# R package build artefacts
.Rbuildignore
.DS_Store
*.Rcheck/
.Rcheck/

# knitr / RMarkdown caches
*_cache/
cache/
*.utf8.md
*.knit.md

# Packrat / renv local environments
packrat/
renv/library/
renv/staging/
renv.lock # optional — keep if you intentionally version‑control it

##############################
# PYTHON (optional tools)
##############################
__pycache__/
*.pyc

##############################
# DATA FILES — as requested
##############################

# Ignore ALL CSV files everywhere
*.csv

# But keep version-control reference data
!data/reference/*.csv

# But keep placeholder files if needed
!data/reference/placeholder.txt
!data/extracts/placeholder.txt

# Ignore Excel files produced by pipeline
*.xlsx
*.xlsm

# Ignore ALL ZIP files everywhere
*.zip

# Ignore large data objects
*.rds
*.RData
*.feather
*.parquet

##############################
# LOGS & OUTPUTS
##############################

# Logs
*.log
outputs/logs/*

# Pipeline outputs
outputs/*.csv
outputs/*.xlsx
outputs/*.html

##############################
# CONFIG & LOCAL ENV FILES
##############################

# Local machine settings
.env
*.env

# Local credentials (NEVER commit secrets)
secrets.yml
credentials.yml
*.key
*.pem

##############################
# OS / EDITOR NOISE
##############################

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# VS Code / other editors
.vscode/
.idea/
*.swp
*.swo

##############################
# SHINY APP STATE
##############################
shiny-app/*.log
shiny-app/.Rhistory
